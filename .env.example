# --- Frontend (read by Vite, safe to expose in the browser) ---
# Supabase project URL and anon/public key.
# Find both in: Supabase dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Welcome email toggle. Leave unset/false while you're on a *.vercel.app URL —
# Resend can't send from an unverified domain, so signups would just log errors.
# Once you've verified a sending domain in Resend (and set the Edge Function
# secrets below), set this to true in Vercel and redeploy to switch it on.
VITE_SEND_WELCOME_EMAIL=false

# --- Edge Function secrets (server-side only — do NOT put these in Vercel/frontend env) ---
# Set these with `supabase secrets set` (see README setup steps). Listed here only
# so you know exactly what to set; this file itself is never read by the Edge Function.
#
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=hello@yourdomain.com
# EMAIL_REPLY_TO=you@yourdomain.com
